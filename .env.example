# Whisper (whisper.cpp)
WHISPER_API_URL=http://localhost:9000
WHISPER_LANGUAGE=pt
# Caminho para o executavel whisper-server (deixe vazio para modo manual)
WHISPER_SERVER_PATH=
# Caminho para o modelo ggml (ex: ggml-base.bin)
WHISPER_MODEL_PATH=

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
# Origens permitidas pelo CORS (separadas por virgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Paths
OUTPUT_DIR=./output

# FFmpeg
FFMPEG_CONCURRENCY=2

# yt-dlp
YTDLP_PATH=yt-dlp
